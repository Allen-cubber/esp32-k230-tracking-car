# Copy to .env on the Raspberry Pi, or export these variables in the shell.

# MQTT broker runs on the Raspberry Pi by default.
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_DEVICE_ID=robot01
MQTT_TOPIC_ROOT=qrs

# Voice and cloud model keys. Do not commit real keys.
XF_APPID=
XF_API_KEY=
XF_API_SECRET=
DASHSCOPE_API_KEY=

# Optional runtime tuning.
WAKE_WORD=小车
MIC_DEVICE=hw:2,0
LLM_MODEL=deepseek-v3
TTS_VOICE=sambert-zhiya-v1
VOICE_DRY_RUN=0
VOICE_ALWAYS_ACTIVE=0
ASR_LISTEN_WINDOW_S=6.0
ASR_RMS_THRESHOLD=500
CONVERSATION_TIMEOUT_S=30
